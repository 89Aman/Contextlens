# ContextLens Backend Environment Variables
# Copy this file to .env and fill in your values.

# ── Required ────────────────────────────────────────────────────────────────

# Google Cloud project ID 
GOOGLE_CLOUD_PROJECT=contextlens-backend-001

# Firebase client config (used to render the sign-in page)
CLIENT_FIREBASE_API_KEY=your-firebase-api-key
CLIENT_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
CLIENT_FIREBASE_PROJECT_ID=your-project-id

