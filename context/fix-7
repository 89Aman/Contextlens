    const ref = collection(
      db,
      'users', uid,
      'projects', projectId,
      'episodes', episodeId,
      'calls'
    );
    const q = query(ref, orderBy('createdAt', 'asc'));

    const unsub = onSnapshot(
      q,
      (snap) => {
        const data: Call[] = snap.docs.map((d) => ({
          id: d.id,
          ...(d.data() as Omit<Call, 'id'>),
