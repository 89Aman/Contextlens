import { useProjects } from '../hooks/useProjects';

export function HomePage() {
  const { projects, loading, error } = useProjects();

  if (loading) {
    return <div>Loading projects...</div>;
  }

  if (error) {
    return <div>Error: {error}</div>;
  }

  if (projects.length === 0) {
    return (
      <div>
        <p>No projects yet.</p>
        <p>Open a repo in VS Code with ContextLens installed.</p>
      </div>
    );
  }

  return (
    <div>
      {projects.map((project) => (
        <div key={project.id}>
          <h3>{project.name}</h3>
          <p>{project.localWorkspaceName}</p>
          <p>Branch: {project.defaultBranch}</p>
          <a href={`/dashboard/${project.id}`}>View Episodes</a>
        </div>
      ))}
    </div>
  );
}
