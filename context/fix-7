FIX 6 — BACKEND AUTH MIDDLEWARE (PROPER LONG-TERM FIX)
================================================================

FILE: functions/src/routes/api.js
  OR: functions/index.js
  (wherever your Express app middleware is defined)

FIND this block (your current demo middleware):

  app.use((req, res, next) => {
    req.context = { uid: 'contextlens-demo-user' };
    next();
  });

REPLACE with:

----------------------------------------------------------------
const admin = require('firebase-admin');

app.use(async (req, res, next) => {
  try {
    const authHeader = req.headers.authorization;

    if (authHeader && authHeader.startsWith('Bearer ')) {
      const token = authHeader.split('Bearer ')[1];
      const decoded = await admin.auth().verifyIdToken(token);
      req.context = {
        uid: decoded.uid,
        email: decoded.email || null,
        name: decoded.name || null,
      };
    } else {
      // No token — use demo user for testing only
      req.context = { uid: 'contextlens-demo-user' };
    }

    next();
  } catch (err) {
    // Token invalid or expired — fallback to demo user
    console.warn('Auth fallback to demo-user:', err.message);
    req.context = { uid: 'contextlens-demo-user' };
    next();
  }
});
