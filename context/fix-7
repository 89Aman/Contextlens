import { useEffect, useState } from 'react';
import { collection, onSnapshot, query, orderBy } from 'firebase/firestore';
import { db, auth } from '../lib/firebase';

export interface Project {
  id: string;
  name: string;
  repoUrl: string | null;
  localWorkspaceName: string;
  defaultBranch: string;
  createdAt: any;
  updatedAt: any;
  settings?: {
    preferredModel?: string;
    redactionEnabled?: boolean;
    autoSummariesEnabled?: boolean;
  };
}

export function useProjects() {
  const [projects, setProjects] = useState<Project[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  useEffect(() => {
    // KEY FIX: fall back to contextlens-demo-user
    const uid = auth.currentUser?.uid || 'contextlens-demo-user';

    if (!uid) {
      setLoading(false);
      setError('No user session');
      return;
    }

    const ref = collection(db, 'users', uid, 'projects');
    const q = query(ref, orderBy('createdAt', 'desc'));

    const unsub = onSnapshot(
      q,
      (snap) => {
        const data: Project[] = snap.docs.map((d) => ({
          id: d.id,
          ...(d.data() as Omit<Project, 'id'>),
        }));
        setProjects(data);
        setLoading(false);
        setError(null);
      },
      (err) => {
        console.error('useProjects error:', err);
        setError(err.message);
        setLoading(false);
      }
    );

    return () => unsub();
  }, [auth.currentUser?.uid]);

  return { projects, loading, error };
}
